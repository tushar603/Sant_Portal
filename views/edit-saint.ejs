<!DOCTYPE html>
<html>
<head>
    <title>Edit <%= saint.name %> - Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Segoe UI',sans-serif; background:#f5f5f5; }
        .header {
            background:linear-gradient(135deg,#8b0000,#dc143c);
            padding:20px 30px; color:white;
            display:flex; justify-content:space-between; align-items:center;
        }
        .header h1 { font-size:1.6em; }
        .header a {
            color:white; text-decoration:none;
            background:rgba(255,255,255,0.2); padding:8px 18px;
            border-radius:20px; font-size:0.9em;
        }
        .form-container {
            background:white; padding:40px; border-radius:16px;
            max-width:800px; margin:30px auto;
            box-shadow:0 6px 30px rgba(0,0,0,0.12);
        }
        h2 { color:#8b0000; margin-bottom:25px; font-size:1.6em;
            border-bottom:3px solid #8b0000; padding-bottom:12px; }
        .field-group { margin-bottom:18px; }
        label { display:block; color:#444; font-weight:600; margin-bottom:5px; font-size:0.9em; }
        input, textarea, select {
            width:100%; padding:12px 14px; border:2px solid #ddd;
            border-radius:8px; font-size:14px; font-family:inherit; transition:0.2s;
        }
        input:focus, textarea:focus, select:focus {
            outline:none; border-color:#8b0000;
            box-shadow:0 0 8px rgba(139,0,0,0.15);
        }
        textarea { resize:vertical; min-height:100px; }
        .row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
        .section-label {
            font-size:0.75em; font-weight:700; text-transform:uppercase;
            letter-spacing:1px; color:#8b0000; margin:24px 0 12px;
            padding-bottom:6px; border-bottom:1px solid #f0e0e0;
        }
        button[type="submit"] {
            padding:14px 40px; background:linear-gradient(135deg,#8b0000,#dc143c);
            color:white; border:none; border-radius:8px; cursor:pointer;
            font-size:16px; font-weight:600; margin-top:10px; transition:0.2s;
        }
        button[type="submit"]:hover { transform:translateY(-2px); box-shadow:0 4px 15px rgba(139,0,0,0.3); }
    </style>
</head>
<body>
    <div class="header">
        <h1>✏️ Edit Saint</h1>
        <a href="/admin/saints">← Back to List</a>
    </div>

    <div class="form-container">
        <h2><%= saint.name %></h2>

        <form action="/admin/edit/<%= saint._id %>" method="POST">

            <div class="section-label">Basic Info</div>
            <div class="row">
                <div class="field-group">
                    <label>Name (English)</label>
                    <input type="text" name="name" value="<%= saint.name %>" required>
                </div>
                <div class="field-group">
                    <label>Name (Marathi)</label>
                    <input type="text" name="nameMarathi" value="<%= saint.nameMarathi || '' %>">
                </div>
            </div>

            <div class="row">
                <div class="field-group">
                    <label>Birth Year</label>
                    <input type="text" name="birthYear" value="<%= saint.birthYear || '' %>">
                </div>
                <div class="field-group">
                    <label>Region</label>
                    <input type="text" name="region" value="<%= saint.region || '' %>" placeholder="e.g., Marathwada">
                </div>
            </div>

            <div class="row">
                <div class="field-group">
                    <label>Birth Place (English)</label>
                    <input type="text" name="birthPlace" value="<%= saint.birthPlace || '' %>">
                </div>
                <div class="field-group">
                    <label>Birth Place (Marathi)</label>
                    <input type="text" name="birthPlaceMarathi" value="<%= saint.birthPlaceMarathi || '' %>">
                </div>
            </div>

            <div class="row">
                <div class="field-group">
                    <label>God Followed (English)</label>
                    <input type="text" name="godFollowed" value="<%= saint.godFollowed || '' %>">
                </div>
                <div class="field-group">
                    <label>God Followed (Marathi)</label>
                    <input type="text" name="godFollowedMarathi" value="<%= saint.godFollowedMarathi || '' %>">
                </div>
            </div>

            <div class="section-label">History & Biography</div>
            <div class="field-group">
                <label>History (English)</label>
                <textarea name="history" rows="6"><%= saint.history || '' %></textarea>
            </div>
            <div class="field-group">
                <label>History (Marathi)</label>
                <textarea name="historyMarathi" rows="6"><%= saint.historyMarathi || '' %></textarea>
            </div>

            <div class="section-label">Literature & Works</div>
            <div class="field-group">
                <label>Literature (English)</label>
                <textarea name="literature" rows="4"><%= saint.literature || '' %></textarea>
            </div>
            <div class="field-group">
                <label>Literature (Marathi)</label>
                <textarea name="literatureMarathi" rows="4"><%= saint.literatureMarathi || '' %></textarea>
            </div>

            <div class="section-label">Mantra & Stotra</div>
            <div class="field-group">
                <label>Mantra</label>
                <textarea name="mantra" rows="2"><%= saint.mantra || '' %></textarea>
            </div>
            <div class="field-group">
                <label>Stotra</label>
                <textarea name="stotra" rows="5"><%= saint.stotra || '' %></textarea>
            </div>

            <div class="section-label">Media & Location</div>
            <div class="row">
                <div class="field-group">
                    <label>Image File Name</label>
                    <input type="text" name="image" value="<%= saint.image || '' %>">
                </div>
                <div class="field-group">
                    <label>Audio File Name</label>
                    <input type="text" name="audio" value="<%= saint.audio || '' %>">
                </div>
            </div>
            <div class="field-group">
                <label>Google Maps Embed URL</label>
                <input type="text" name="mapLocation" value="<%= saint.mapLocation || '' %>">
            </div>

            <button type="submit">💾 Save Changes</button>
        </form>
    </div>
</body>
</html>
