<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel - Sant Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #ff9a56 0%, #ff6a88 50%, #ff99ac 100%);
            padding: 0;
            min-height: 100vh;
        }
        .header {
            background: linear-gradient(135deg, #8b0000 0%, #dc143c 100%);
            padding: 30px;
            color: white;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        h1 {
            font-size: 2em;
            margin: 0;
        }
        .logout-btn { 
            background: rgba(255, 255, 255, 0.2);
            padding: 12px 25px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            color: white;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
        }
        .logout-btn:hover { 
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.05);
        }
        .form-container { 
            background: white;
            padding: 40px;
            border-radius: 20px;
            max-width: 800px;
            margin: 40px auto;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        h2 {
            color: #8b0000;
            margin-bottom: 30px;
            font-size: 1.8em;
            border-bottom: 3px solid #8b0000;
            padding-bottom: 15px;
        }
        input, textarea { 
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            border: 2px solid #ddd;
            border-radius: 10px;
            font-size: 15px;
            font-family: inherit;
            transition: 0.3s;
        }
        input:focus, textarea:focus {
            outline: none;
            border-color: #8b0000;
            box-shadow: 0 0 10px rgba(139, 0, 0, 0.2);
        }
        textarea {
            resize: vertical;
            min-height: 100px;
        }
        button[type="submit"] { 
            padding: 15px 40px;
            background: linear-gradient(135deg, #8b0000 0%, #dc143c 100%);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-size: 18px;
            font-weight: 600;
            margin-top: 20px;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(139, 0, 0, 0.3);
        }
        button[type="submit"]:hover { 
            background: linear-gradient(135deg, #dc143c 0%, #ff1744 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(220, 20, 60, 0.4);
        }
        .field-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            color: #555;
            font-weight: 600;
            margin-bottom: 5px;
        }
    </style>
</head>
<body>

    <div class="header">
        <h1>Admin Dashboard</h1>
        <div style="display:flex;gap:10px;">
            <a href="/admin/saints">
                <button class="logout-btn">✏️ Edit Saints</button>
            </a>
            <a href="/logout">
                <button class="logout-btn">Logout</button>
            </a>
        </div>
    </div>

    <div class="form-container">
        <h2>Add New Saint</h2>

        <form action="/admin/add-saint" method="POST" enctype="multipart/form-data">
            
            <div class="field-group">
                <label>Saint Name (English) *</label>
                <input type="text" name="name" placeholder="e.g., Sant Tukaram Maharaj" required>
            </div>

            <div class="field-group">
                <label>Saint Name (Marathi)</label>
                <input type="text" name="nameMarathi" placeholder="e.g., संत तुकाराम महाराज">
            </div>

            <div class="field-group">
                <label>Birth Year *</label>
                <input type="text" name="birthYear" placeholder="e.g., 1608" required>
            </div>

            <div class="field-group">
                <label>Birth Place (English) *</label>
                <input type="text" name="birthPlace" placeholder="e.g., Dehu, Pune" required>
            </div>

            <div class="field-group">
                <label>Birth Place (Marathi)</label>
                <input type="text" name="birthPlaceMarathi" placeholder="e.g., देहू, पुणे">
            </div>

            <div class="field-group">
                <label>God Followed (English) *</label>
                <input type="text" name="godFollowed" placeholder="e.g., Vitthal, Lord Rama" required>
            </div>

            <div class="field-group">
                <label>God Followed (Marathi)</label>
                <input type="text" name="godFollowedMarathi" placeholder="e.g., विठ्ठल, भगवान राम">
            </div>

            <div class="field-group">
                <label>History & Biography (English) *</label>
                <textarea name="history" rows="6" placeholder="Write the saint's history and biography in English..." required></textarea>
            </div>

            <div class="field-group">
                <label>History & Biography (Marathi)</label>
                <textarea name="historyMarathi" rows="6" placeholder="Write the saint's history and biography in Marathi..."></textarea>
            </div>

            <div class="field-group">
                <label>Literature & Works (English) *</label>
                <textarea name="literature" rows="4" placeholder="Describe the saint's literary works..." required></textarea>
            </div>

            <div class="field-group">
                <label>Literature & Works (Marathi)</label>
                <textarea name="literatureMarathi" rows="4" placeholder="Describe the saint's literary works in Marathi..."></textarea>
            </div>

            <div class="field-group">
                <label>Mantra (Optional)</label>
                <textarea name="mantra" rows="2" placeholder="e.g., विठ्ठल विठ्ठल विठोबा विठ्ठल"></textarea>
            </div>

            <div class="field-group">
                <label>Stotra (Optional)</label>
                <textarea name="stotra" rows="6" placeholder="Write the stotra..."></textarea>
            </div>

            <div class="field-group">
                <label>Audio File Name (Optional)</label>
                <input type="text" name="audio" placeholder="e.g., tukaram-mantra.mp3">
            </div>

            <div class="field-group">
                <label>Image File Name *</label>
                <input type="text" name="image" placeholder="e.g., tukaram.jpg" required>
            </div>

            <div class="field-group">
                <label>Google Maps Embed URL (Optional)</label>
                <input type="text" name="mapLocation" placeholder="e.g., https://www.google.com/maps/embed?pb=...">
                <small style="color: #666;">Get embed URL from Google Maps > Share > Embed a map</small>
            </div>

            <button type="submit">Add Saint</button>

        </form>
    </div>

</body>
</html>